datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model GameSave {
  id          String   @id @default(uuid())
  saveName    String
  countryName String
  leaderRole  String
  currentYear Int
  currentTurn Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  nationState NationState?
  factions    Faction[]
  newsItems   NewsItem[]
  timeline    TimelineEvent[]
  diplomacy   DiplomacyRelation[]
}

model NationState {
  id         String   @id @default(uuid())
  gameSaveId String   @unique
  gameSave   GameSave @relation(fields: [gameSaveId], references: [id], onDelete: Cascade)

  // Economy
  gdp              Float
  inflation        Float
  unemployment     Float
  debt             Float
  currencyStrength Float
  foreignInvestment Float

  // Society
  happiness  Float
  literacy   Float
  healthcare Float
  crimeRate  Float
  inequality Float

  // Politics
  approvalRating Float
  corruption     Float
  stability      Float
  polarization   Float

  // Military
  readiness         Float
  manpower          Float
  technology        Float
  nuclearCapability Float

  // Environment
  pollution      Float
  energySecurity Float
  climateRisk    Float

  // Advisor Reports (stored as JSON string or individual text fields)
  advisorReportsJson String @default("{}")
}

model Faction {
  id         String   @id @default(uuid())
  gameSaveId String
  gameSave   GameSave @relation(fields: [gameSaveId], references: [id], onDelete: Cascade)
  name       String
  support    Float
  influence  Float
}

model NewsItem {
  id         String   @id @default(uuid())
  gameSaveId String
  gameSave   GameSave @relation(fields: [gameSaveId], references: [id], onDelete: Cascade)
  year       Int
  turn       Int
  headline   String
  category   String
  summary    String
  createdAt  DateTime @default(now())
}

model TimelineEvent {
  id          String   @id @default(uuid())
  gameSaveId  String
  gameSave    GameSave @relation(fields: [gameSaveId], references: [id], onDelete: Cascade)
  year        Int
  turn        Int
  title       String
  description String
  impact      String?
  createdAt   DateTime @default(now())
}

model DiplomacyRelation {
  id            String   @id @default(uuid())
  gameSaveId    String
  gameSave      GameSave @relation(fields: [gameSaveId], references: [id], onDelete: Cascade)
  targetCountry String
  relationScore Float
}
